# Auth — generate: openssl rand -base64 32
AUTH_SECRET=your-random-auth-secret

# Admin account(s) — comma-separated emails get admin role on signup
ADMIN_EMAIL=mn-oiseibrobbey6423@gmail.com

# VAPID keys for Web Push — regenerate: node scripts/generate-vapid-keys.js
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-public-key-here
VAPID_PRIVATE_KEY=your-private-key-here
VAPID_SUBJECT=mailto:isaac@umat.edu.gh

# Cron auth for /api/cron/reminders (Vercel Hobby has no minute cron — use cron-job.org → GET every 5 min)
CRON_SECRET=your-random-secret

# Google Gemini — AI study plan optimizer (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key

# Redis on Vercel (from Storage → your DB → .env.local tab)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# Or Upstash direct names:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
